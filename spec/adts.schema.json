{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adts.dev/schema/adts-0.2.schema.json",
  "title": "ADTS 0.2 (Avalonia 11)",
  "description": "Avalonia Design Token Schema with domain tokens and Avalonia projection mappings.",
  "type": "object",
  "required": [
    "$schema",
    "adtsVersion",
    "metadata",
    "tokens",
    "avalonia"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "adtsVersion": {
      "type": "string",
      "const": "0.2.0"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "framework",
        "frameworkVersionRange"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "framework": {
          "type": "string",
          "const": "Avalonia"
        },
        "frameworkVersionRange": {
          "type": "string",
          "pattern": "^11(\\..+)?$"
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tokens": {
      "type": "object",
      "required": [
        "colors",
        "typography",
        "spacing",
        "rounded",
        "components"
      ],
      "additionalProperties": false,
      "properties": {
        "colors": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/colorOrRef"
          }
        },
        "typography": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/typographyToken"
          }
        },
        "spacing": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/literalOrTokenRef"
          }
        },
        "rounded": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/literalOrTokenRef"
          }
        },
        "elevation": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/literalOrTokenRef"
          }
        },
        "components": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "$ref": "#/$defs/literalOrTokenRef"
            }
          }
        }
      }
    },
    "avalonia": {
      "type": "object",
      "required": [
        "resources",
        "styles"
      ],
      "additionalProperties": false,
      "properties": {
        "app": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "theme": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "base": {
                  "type": "string",
                  "enum": [
                    "Fluent",
                    "Simple"
                  ]
                },
                "requestedVariant": {
                  "type": "string",
                  "enum": [
                    "Default",
                    "Light",
                    "Dark"
                  ]
                }
              }
            }
          }
        },
        "resources": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/literalOrTokenRef"
          }
        },
        "variants": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "Light": {
              "$ref": "#/$defs/variantDefinition"
            },
            "Dark": {
              "$ref": "#/$defs/variantDefinition"
            },
            "Default": {
              "$ref": "#/$defs/variantDefinition"
            }
          }
        },
        "styles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/styleDefinition"
          }
        },
        "styleStates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/styleStateDefinition"
          }
        },
        "controlThemes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/controlThemeDefinition"
          }
        }
      }
    }
  },
  "$defs": {
    "tokenReference": {
      "type": "string",
      "pattern": "^\\{tokens\\.[^}]+\\}$"
    },
    "colorHex": {
      "type": "string",
      "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
    },
    "colorOrRef": {
      "oneOf": [
        {
          "$ref": "#/$defs/colorHex"
        },
        {
          "$ref": "#/$defs/tokenReference"
        }
      ]
    },
    "literalOrTokenRef": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "$ref": "#/$defs/tokenReference"
        }
      ]
    },
    "typographyToken": {
      "type": "object",
      "required": [
        "fontFamily",
        "fontSize",
        "fontWeight"
      ],
      "additionalProperties": false,
      "properties": {
        "fontFamily": {
          "type": "string",
          "minLength": 1
        },
        "fontSize": {
          "$ref": "#/$defs/literalOrTokenRef"
        },
        "fontWeight": {
          "$ref": "#/$defs/literalOrTokenRef"
        },
        "lineHeight": {
          "$ref": "#/$defs/literalOrTokenRef"
        },
        "letterSpacing": {
          "$ref": "#/$defs/literalOrTokenRef"
        }
      }
    },
    "styleDefinition": {
      "type": "object",
      "required": [
        "selector",
        "setters"
      ],
      "additionalProperties": false,
      "properties": {
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "setters": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/literalOrTokenRef"
          }
        }
      }
    },
    "styleStateDefinition": {
      "type": "object",
      "required": [
        "baseSelector",
        "stateSelector",
        "setters"
      ],
      "additionalProperties": false,
      "properties": {
        "baseSelector": {
          "type": "string",
          "minLength": 1
        },
        "stateSelector": {
          "type": "string",
          "pattern": "^\\^:[a-zA-Z0-9_-]+$"
        },
        "setters": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/literalOrTokenRef"
          }
        }
      }
    },
    "variantDefinition": {
      "type": "object",
      "required": [
        "resources"
      ],
      "additionalProperties": false,
      "properties": {
        "resources": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/literalOrTokenRef"
          }
        }
      }
    },
    "controlThemeDefinition": {
      "type": "object",
      "required": [
        "targetType",
        "setters"
      ],
      "additionalProperties": false,
      "properties": {
        "targetType": {
          "type": "string",
          "minLength": 1
        },
        "xKey": {
          "type": "string",
          "minLength": 1
        },
        "basedOnFluent": {
          "type": "boolean",
          "description": "If true, generated theme is intended to overlay Fluent defaults."
        },
        "setters": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/literalOrTokenRef"
          }
        },
        "states": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "$ref": "#/$defs/literalOrTokenRef"
            }
          }
        }
      }
    }
  }
}
