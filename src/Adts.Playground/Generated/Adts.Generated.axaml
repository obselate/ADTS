<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="adts.color.surface.canvas">#FFFFFFFF</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.surface.card">#FFF2F2F2</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.text.primary">#FF000000</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.text.secondary">#FF595959</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.text.inverse">#FFFFFFFF</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.brand.primary">#FF000000</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.border.default">#FFD9D9D9</SolidColorBrush>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="adts.color.surface.canvas">#FF000000</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.surface.card">#FF1A1A1A</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.text.primary">#FFFFFFFF</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.text.secondary">#FFD9D9D9</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.text.inverse">#FF000000</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.brand.primary">#FFFFFFFF</SolidColorBrush>
          <SolidColorBrush x:Key="adts.color.border.default">#FF595959</SolidColorBrush>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
      <SolidColorBrush x:Key="adts.color.neutral.100">#FFFFFFFF</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.neutral.200">#FFF2F2F2</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.neutral.300">#FFE6E6E6</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.neutral.400">#FFD9D9D9</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.neutral.500">#FFBFBFBF</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.neutral.600">#FF8C8C8C</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.neutral.700">#FF595959</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.neutral.800">#FF262626</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.neutral.900">#FF000000</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.surface.canvas">#FFFFFFFF</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.surface.card">#FFF2F2F2</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.text.primary">#FF000000</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.text.secondary">#FF595959</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.text.inverse">#FFFFFFFF</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.border.default">#FFD9D9D9</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.brand.primary">#FF000000</SolidColorBrush>
      <x:Double x:Key="adts.spacing.100">8</x:Double>
      <x:Double x:Key="adts.spacing.200">12</x:Double>
      <x:Double x:Key="adts.spacing.300">16</x:Double>
      <x:Double x:Key="adts.spacing.400">20</x:Double>
      <x:Double x:Key="adts.radius.sm">6</x:Double>
      <x:Double x:Key="adts.radius.md">10</x:Double>
      <x:Double x:Key="adts.radius.lg">14</x:Double>
      <x:Double x:Key="adts.typography.weight.100">100</x:Double>
      <x:Double x:Key="adts.typography.weight.200">200</x:Double>
      <x:Double x:Key="adts.typography.weight.300">300</x:Double>
      <x:Double x:Key="adts.typography.weight.400">400</x:Double>
      <x:Double x:Key="adts.typography.weight.500">500</x:Double>
      <x:Double x:Key="adts.typography.weight.600">600</x:Double>
      <x:Double x:Key="adts.typography.weight.700">700</x:Double>
      <x:Double x:Key="adts.typography.weight.800">800</x:Double>
      <x:Double x:Key="adts.typography.weight.900">900</x:Double>
      <!-- Generated control themes -->
      <!-- PrimaryButtonTheme: basedOnFluent=true -->
      <ControlTheme x:Key="PrimaryButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource adts.color.brand.primary}" />
        <Setter Property="Foreground" Value="{DynamicResource adts.color.text.inverse}" />
        <Setter Property="CornerRadius" Value="10" />
        <Style Selector="^:pointerover">
          <Setter Property="Opacity" Value="0.85" />
        </Style>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>
  <Style Selector="TextBlock.heading">
    <Setter Property="FontFamily" Value="Inter" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="800" />
    <Setter Property="Foreground" Value="{DynamicResource adts.color.brand.primary}" />
  </Style>
  <Style Selector="TextBlock.subheading">
    <Setter Property="FontFamily" Value="Inter" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="700" />
    <Setter Property="Foreground" Value="{DynamicResource adts.color.brand.primary}" />
  </Style>
  <Style Selector="TextBlock.body-secondary">
    <Setter Property="FontFamily" Value="Inter" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="400" />
    <Setter Property="Foreground" Value="{DynamicResource adts.color.text.secondary}" />
  </Style>
  <Style Selector="TextBlock.weight-100">
    <Setter Property="FontWeight" Value="100" />
  </Style>
  <Style Selector="TextBlock.weight-200">
    <Setter Property="FontWeight" Value="200" />
  </Style>
  <Style Selector="TextBlock.weight-300">
    <Setter Property="FontWeight" Value="300" />
  </Style>
  <Style Selector="TextBlock.weight-400">
    <Setter Property="FontWeight" Value="400" />
  </Style>
  <Style Selector="TextBlock.weight-500">
    <Setter Property="FontWeight" Value="500" />
  </Style>
  <Style Selector="TextBlock.weight-600">
    <Setter Property="FontWeight" Value="600" />
  </Style>
  <Style Selector="TextBlock.weight-700">
    <Setter Property="FontWeight" Value="700" />
  </Style>
  <Style Selector="TextBlock.weight-800">
    <Setter Property="FontWeight" Value="800" />
  </Style>
  <Style Selector="TextBlock.weight-900">
    <Setter Property="FontWeight" Value="900" />
  </Style>
  <Style Selector="Border.card">
    <Setter Property="Padding" Value="20" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource adts.color.surface.card}" />
    <Setter Property="BorderBrush" Value="{DynamicResource adts.color.border.default}" />
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource adts.color.brand.primary}" />
    <Setter Property="Foreground" Value="{DynamicResource adts.color.text.inverse}" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource adts.color.border.default}" />
  </Style>
  <Style Selector="Button.primary:pointerover">
    <Setter Property="Opacity" Value="0.85" />
  </Style>
</Styles>
