<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="adts.color.surface.canvas">#FF120E05</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.surface.card">#FF2A220F</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.text.primary">#FFFFF4CC</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.text.secondary">#FFE6BE66</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.text.inverse">#FF120E05</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.border.default">#FFB38D2D</SolidColorBrush>
      <SolidColorBrush x:Key="adts.color.brand.primary">#FFFFE8A3</SolidColorBrush>
      <x:Double x:Key="adts.spacing.100">8</x:Double>
      <x:Double x:Key="adts.spacing.200">12</x:Double>
      <x:Double x:Key="adts.spacing.300">16</x:Double>
      <x:Double x:Key="adts.spacing.400">20</x:Double>
      <x:Double x:Key="adts.radius.sm">4</x:Double>
      <x:Double x:Key="adts.radius.md">8</x:Double>
      <x:Double x:Key="adts.radius.lg">12</x:Double>
      <x:Double x:Key="adts.typography.weight.100">100</x:Double>
      <x:Double x:Key="adts.typography.weight.200">200</x:Double>
      <x:Double x:Key="adts.typography.weight.300">300</x:Double>
      <x:Double x:Key="adts.typography.weight.400">400</x:Double>
      <x:Double x:Key="adts.typography.weight.500">500</x:Double>
      <x:Double x:Key="adts.typography.weight.600">600</x:Double>
      <x:Double x:Key="adts.typography.weight.700">700</x:Double>
      <x:Double x:Key="adts.typography.weight.800">800</x:Double>
      <x:Double x:Key="adts.typography.weight.900">900</x:Double>
      <!-- Generated control themes -->
      <!-- StatusBadgeTheme: basedOnFluent=false -->
      <ControlTheme x:Key="StatusBadgeTheme" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource adts.color.border.default}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="CornerRadius" Value="4" />
        <Style Selector="^:pointerover">
          <Setter Property="Opacity" Value="0.92" />
        </Style>
      </ControlTheme>
      <!-- PillTagTheme: basedOnFluent=false -->
      <ControlTheme x:Key="PillTagTheme" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource adts.color.surface.card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource adts.color.border.default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="12" />
        <Style Selector="^:pointerover">
          <Setter Property="BorderThickness" Value="1" />
        </Style>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>
  <Style Selector="TextBlock.heading">
    <Setter Property="FontFamily" Value="Inter" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="800" />
    <Setter Property="Foreground" Value="{DynamicResource adts.color.text.primary}" />
  </Style>
  <Style Selector="TextBlock.subheading">
    <Setter Property="FontFamily" Value="Inter" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="700" />
    <Setter Property="Foreground" Value="{DynamicResource adts.color.text.primary}" />
  </Style>
  <Style Selector="TextBlock.body-secondary">
    <Setter Property="FontFamily" Value="Inter" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="400" />
    <Setter Property="Foreground" Value="{DynamicResource adts.color.text.secondary}" />
  </Style>
  <Style Selector="Border.card">
    <Setter Property="Padding" Value="20" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource adts.color.surface.card}" />
    <Setter Property="BorderBrush" Value="{DynamicResource adts.color.border.default}" />
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource adts.color.brand.primary}" />
    <Setter Property="Foreground" Value="{DynamicResource adts.color.text.inverse}" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource adts.color.border.default}" />
  </Style>
  <Style Selector="Button.primary:pointerover">
    <Setter Property="Opacity" Value="0.9" />
  </Style>
  <Style Selector="Button.primary:pressed">
    <Setter Property="Opacity" Value="0.75" />
  </Style>
</Styles>
